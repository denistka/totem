v:2
format:totem-testing
purpose:machine-only testing strategy + model tiers + risks + definition of done

###############################################################################
# MODEL TIERS (cost allocation)
###############################################################################

model-tiers:
  expensive:[Opus,GPT-4,architecture-security-complex-algorithms,auth-API-client-state-mgmt]
  average:[Sonnet,GPT-4-mini,standard-features-UI,forms-lists-CRUD]
  inexpensive:[Haiku,GPT-3.5,boilerplate-config-translations,config-i18n-simple-components]

###############################################################################
# AUTOMATED TESTS (per sprint)
###############################################################################

auto:
  unit:[business-logic,utilities,stores]
  component:[Vue-Vitest]
  e2e:[Playwright-critical-flows]

###############################################################################
# MANUAL TESTING FLOWS
###############################################################################

manual:
  login-vehicles-map:[Critical,S-04+]
  track-playback:[High,S-11+]
  report-generation:[High,S-14+]
  push-notification-map:[High,S-15+]
  settings-persistence:[Medium,S-16+]

###############################################################################
# QA CHECKPOINTS
###############################################################################

qa-checkpoints:
  sprint-review:Demo-all-completed-features
  regression:Full-E2E-before-release
  uat:Client-testing-S-17-S-18

###############################################################################
# RISK MITIGATION
###############################################################################

risks:
  JWT-API-not-ready:[Mock-API-flexible-adapter,CTO]
  map-performance:[Early-prototyping-S-07,Dev]
  store-rejection:[Platform-guidelines-review-S-17,PM]
  push-issues:[Multi-device-testing-S-15,QA]

###############################################################################
# DEFINITION OF DONE (global)
###############################################################################

done:
  - lint-pass-ESLint-Rust-clippy
  - unit-tests-pass
  - component-renders-no-errors
  - works-iOS-Android-Web-as-applicable
  - no-TypeScript-errors
  - PR-reviewed-merged
  - docs-updated

###############################################################################
# SPRINT DEFINITION FILES (path per sprint)
###############################################################################

definitions-catalog:
  S01:sprint-01-setup
  S02:sprint-02-api-design
  S03:sprint-03-auth-core
  S04:sprint-04-auth-complete
  S05:sprint-05-vehicles-core
  S06:sprint-06-vehicles-actions
  S07:sprint-07-map-google
  S08:sprint-08-map-osm
  S09:sprint-09-map-features
  S10:sprint-10-history
  S11:sprint-11-playback
  S12:sprint-12-tracking-complete
  S13:sprint-13-reports-ui
  S14:sprint-14-reports-export
  S15:sprint-15-events
  S16:sprint-16-settings
  S17:sprint-17-platform
  S18:sprint-18-release
  S19:sprint-19-glass-ui
  S20:sprint-20-universal-ui-template
  S21:sprint-21-rebrand-login
  S22:sprint-22-refs-glass-icons-layout
  S23:sprint-23-refs-realtime-tech-qa
  S24:sprint-24-bg-animation
definitions-path:removed-totem/sprints

###############################################################################
# HUMAN SOURCE
###############################################################################

source:removed-content-in-TOTEM_SPRINTS.ti
