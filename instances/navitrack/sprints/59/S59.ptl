# TRACKS (sequential: A → B → C → D → E → F → G → H)
###############################################################################

track-a-modal-system:
  desc: Bottom-anchored modals; dynamic height; scroll under footer; Date/Time (remove time cancel); Report/Vehicle/Objects filter standardization.
  tasks: [S59-TA1, S59-TA2, S59-TA3, S59-TA4]
  requires: [FRONTEND_DEV]
  gate: OPEN

track-b-map-enhancements:
  desc: Map full height with transparency under header/footer; popup margins; layer switcher transparent and flat.
  tasks: [S59-TB1, S59-TB2]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-a-modal-system

track-c-objects-page:
  desc: Search styling (no rounded corners, header height, 1px bottom highlight, spacing); time filter proper format.
  tasks: [S59-TC1, S59-TC2]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-b-map-enhancements

track-d-history-and-object-details:
  desc: History Events tabs and back button; Object Select history like tracking; Object Details scroll logic and API.
  tasks: [S59-TD1, S59-TD2, S59-TD3]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-c-objects-page

track-e-loader-tracking-theme-settings:
  desc: Loader animation redesign; Tracking validation and icons; Theme cycle; Settings accordion styling.
  tasks: [S59-TE1, S59-TE2, S59-TE3, S59-TE4]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-d-history-and-object-details

track-f-pwa-and-analytics:
  desc: PWA behavior study (theme/tome); screen fill and rotation spacing; Tracking Player analytics from old apps.
  tasks: [S59-TF1, S59-TF2]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-e-loader-tracking-theme-settings

track-g-refactoring-optimization:
  desc: Refactoring and optimizing code; reduce duplication; improve structure and performance in touched areas.
  tasks: [S59-TG1, S59-TG2]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-f-pwa-and-analytics

track-h-testing:
  desc: Visual (modals, map, theme, loader); Functional (API, scroll, modals, time filter); Responsive (rotation, spacing).
  tasks: [S59-TH1]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-g-refactoring-optimization

