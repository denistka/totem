###############################################################################
# RULES
###############################################################################
rules:
  - One component per file, one export per file
  - Sub-components receive props, don't import global state
  - Parent screen manages state + passes callbacks
  - File names: kebab-case (vehicle-list-item.tsx)
  - Folders only for complex components (DateRangePicker, ObjectDetails)
  - Don't change functionality — only split
  - Build + lint after each split

###############################################################################
# EXECUTION ORDER (safest first)
###############################################################################
order:
  1. DateRangePicker → extract utils, AnalogClock, TimePicker, CalendarGrid
  2. ObjectsScreen → extract VehicleListItem, vehicle-utils
  3. ObjectDetailsScreen → extract HistoryTab, EventsTab, VehicleInfoPanel
  4. ReportsScreen → extract ReportForm, ReportResultView
  5. TrackingScreen → extract TrackSettingsPanel

###############################################################################
# ACCEPTANCE CRITERIA
###############################################################################
verify:
  - [ ] No screen file > 150 lines (excluding comments/types)
  - [ ] DateRangePicker split into ≥ 4 files
  - [ ] ObjectDetailsScreen split into ≥ 3 sub-components
  - [ ] All sub-components have proper TypeScript props interfaces
  - [ ] Zero functionality changes (visual + behavioral parity)
  - [ ] pnpm run build && pnpm run lint pass
