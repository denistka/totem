track-f-api-and-architecture:
  desc: Global API error and vehicle cache; TrackingActionScreen report API; Settings; dead code; hardcoded→API; comprehensive API review.
  tasks: [S60-TF1, S60-TF2, S60-TF3]
  requires: [FRONTEND_DEV]
