track-a-critical-fixes:
  desc: iOS PWA loader safe area; Object Details scroll; History tabs and back; date format; Tracking API.
  tasks: [S60-TA1, S60-TA2, S60-TA3, S60-TA4, S60-TA5]
  requires: [FRONTEND_DEV]
  gate: OPEN

track-b-object-details-and-history:
  desc: Object Details tabs and header content; default date and map init; History/Events list and interaction; History page scroll and expand map.
  tasks: [S60-TB1, S60-TB2, S60-TB3, S60-TB4]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-a-critical-fixes

track-c-reports-and-tracking-screens:
  desc: Reports table structure and fixed column; Tracking no-data toast and footer; Tracking Player controls and map.
  tasks: [S60-TC1, S60-TC2, S60-TC3]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-b-object-details-and-history

track-d-object-list-structure:
  desc: Object list 3-line structure (name/online/date, speed/parking, route with icon).
  tasks: [S60-TD1]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-c-reports-and-tracking-screens

track-e-ui-and-icons:
  desc: Login spacing; dropdown alignment; icon system from iOS; toast messaging.
  tasks: [S60-TE1, S60-TE2, S60-TE3, S60-TE4]
  requires: [FRONTEND_DEV]
  gate: OPEN
