# bottlenecks. Reference existing patterns and ensure consistency.

###############################################################################
# TRACKS (sequential: A → B → C → D → E → F)
###############################################################################

track-a-code-cleanup:
  desc: Remove dead code, eliminate hardcoded lists, consolidate duplicate components.
