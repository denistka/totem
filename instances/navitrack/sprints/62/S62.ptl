  requires: [FRONTEND_DEV]
  gate: LOCKED

track-d-performance-optimization:
  desc: Bundle size optimization, lazy loading, memoization, virtual scrolling.
  tasks: [S62-TD1, S62-TD2, S62-TD3]
  requires: [FRONTEND_DEV]
  gate: LOCKED

track-e-type-safety:
