###############################################################################
# TRACKS (sequential: A → B → C → D → E → F)
###############################################################################

track-a-header:
  desc: Header config, single component, screen-specific left content; replace AppHeader/MobileHeader.
  tasks: [S57-TA1, S57-TA2, S57-TA3, S57-TA4, S57-TA5]
  requires: [FRONTEND_DEV]
  gate: OPEN

track-b-tracking-player:
  desc: Tracking Player layout, timeline, controls; Tracking Action Player; map route display.
  tasks: [S57-TB1, S57-TB2, S57-TB3, S57-TB4]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-a-header

track-c-loader:
  desc: Logo/Loader component (full-fill, notification); integration per use case.
  tasks: [S57-TC1, S57-TC2]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-b-tracking-player

track-d-modals-and-visual:
  desc: Modal unification (objects shell + vehicle/selection internals); visual consistency; animations.
  tasks: [S57-TD1, S57-TD2, S57-TD3]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-c-loader

track-e-state-and-validation:
  desc: Header/screen/loading state; Tracking and Reports rows as query validators.
  tasks: [S57-TE1]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-d-modals-and-visual

track-f-api-and-integration-checks:
  desc: Verify/fix API calls (Object Details history, tracking execute, report build);
        map render for objects/history; report results table (scrollable, fixed first column).
  tasks: [S57-TF1, S57-TF2, S57-TF3, S57-TF4, S57-TF5]
  requires: [FRONTEND_DEV]
  gate: OPEN
  dep: track-e-state-and-validation

