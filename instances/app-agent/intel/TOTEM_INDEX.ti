###############################################################################
# TOTEM INDEX — app-agent
# Load after: totem/totem-v6/index.ti + instances/app-agent/project.config.yml
###############################################################################

project:
  name: app-agent
  codename: tech-company-in-a-box
  tagline: Describing your product makes it exist
  repo: https://github.com/app-agent-io/core
  code: ../../../../app-agent-io/core
  stack: [Nuxt 4, Vue 3, TypeScript, Bun, Turborepo, MCP, Supabase]
  status: S02 chat bootstrap complete (2026-06-18)

brand:
  domain: app-agent.io
  license: MIT

###############################################################################
# LOAD ORDER
###############################################################################

load-order:
  1: BRIEF.md
  2: S02-INVARIANTS.md
  3: intel/LOCAL-DEV-RUNBOOK.md
  4: intel/ARCHITECTURE_MAP.md
  5: intel/PROBLEMS_REGISTER.md
  6: intel/FEATURE_CENSUS.md
  7: intel/MCP_SETUP.md
  on-demand:
    - intel/REPO_INVENTORY.md
    - intel/CURRENT-STATE-AUDIT.md
    - intel/GITHUB_ISSUES_SYNC.md
    - intel/KNOWLEDGE_GAPS.md

###############################################################################
# INTEL ARTIFACTS
###############################################################################

intel:
  runbook: ./LOCAL-DEV-RUNBOOK.md
  audit: ./CURRENT-STATE-AUDIT.md
  architecture: ./ARCHITECTURE_MAP.md
  inventory: ./REPO_INVENTORY.md
  features: ./FEATURE_CENSUS.md
  problems: ./PROBLEMS_REGISTER.md
  github: ./GITHUB_ISSUES_SYNC.md
  mcp: ./MCP_SETUP.md
  gaps: ./KNOWLEDGE_GAPS.md
  s02-dev-smoke: ./S02-DEV-SMOKE.md
  s02-chat-smoke: ./S02-CHAT-SMOKE.md

###############################################################################
# IN-REPO KNOWLEDGE (pull via MCP when coding)
###############################################################################

mcp:
  endpoint: http://localhost:3000/mcp
  start: bun run dev:docs
  key-slugs:
    - layer-cascade
    - feature-knowledge
    - runtime-config
    - authentication
    - integrations

upstream-knowledge: core/docs/knowledge/
upstream-adrs: core/docs/adr/  # archived — prefer MCP explain()

###############################################################################
# PORTS
###############################################################################

ports:
  docs: 3000
  control: 3001
  chat-app: 3002
  demo-dashboard: 3010
  demo-saas: 3011
  demo-landing: 3012
  demo-chat: 3013
  demo-characters: 3014

###############################################################################
# SPRINTS
###############################################################################

sprints:
  current: S02
  history: ../sprints/
  summary: ../sprints/S02-CHAT-BOOTSTRAP-SUMMARY.md
  invariants: ../S02-INVARIANTS.md

next-suggested:
  - S03: Demo typecheck fixes + configurability (#114)
  - S04: Test harness + Supabase integration (#4, #83)
  - S05: MCP knowledge completion (#5, #10, #11)
  - S06: Chat agent product design (#108, temp.md goal 2)

###############################################################################
# MACHINE RULES FOR AGENTS
###############################################################################

agent-rules:
  - Do NOT modify /core/ in customer forks — extend via organization + apps
  - Use MCP explain(slug) — do not preload ADRs
  - Run feature:health after adding SEE annotations
  - Check PROBLEMS_REGISTER P0 before claiming repo is green
  - temp.md contains secrets — never copy into Totem

updated: 2026-06-18
